{
  "name": "parrafos",
  "private": true,
  "type": "module",
  "scripts": {
    "db:push": "supabase db push",
    "update-types": "dotenv -e .env -- sh -c 'npx supabase gen types typescript --project-id \"$SUPABASE_PROJECT_REF\" --schema public > src/database.types.ts'",
    "update-types:local": "npx supabase gen types typescript --local --schema public > src/database.types.ts",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "worker:runs": "dotenv -e .env -- tsx src/scripts/run-worker.ts"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@supabase/supabase-js": "^2.49.1",
    "cheerio": "^1.2.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "supabase": ">=1.8.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
