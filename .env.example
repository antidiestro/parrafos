# Hosted Supabase project (Settings → API). Default workflow: develop against this DB; use Docker only if you opt into local Supabase.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Public anon key — safe for browser / user-facing clients (RLS applies)
SUPABASE_ANON_KEY=

# Service role — server-side only; never expose to client bundles. Required for the Next.js app (all DB access uses this key on the server).
SUPABASE_SERVICE_ROLE_KEY=

# Used by npm run update-types (Project Settings → General → Reference ID)
SUPABASE_PROJECT_REF=

# Next.js admin (/admin): password login + signed session cookie (long random string, e.g. openssl rand -hex 32)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
