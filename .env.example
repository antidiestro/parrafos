# Canonical public site URL (no trailing slash). Used for Open Graph / social card absolute URLs at build time.
# In production (e.g. Netlify), set this to your live origin (https://your-domain.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional. Google Analytics 4 measurement ID (G-…). Loaded via @next/third-parties/google in the root layout when set.
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Hosted Supabase project (Settings → API). Default workflow: develop against this DB; use Docker only if you opt into local Supabase.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Public anon key — safe for browser / user-facing clients (RLS applies)
SUPABASE_ANON_KEY=

# Service role — server-side only; never expose to client bundles. Required for the Next.js app (all DB access uses this key on the server).
SUPABASE_SERVICE_ROLE_KEY=

# Used by npm run update-types (Project Settings → General → Reference ID)
SUPABASE_PROJECT_REF=

# Optional. If set (0–100), npm run generate-brief stops after discovery when the share of
# canonical URLs not in the latest snapshot (from a prior successful brief) is below this value:
# it updates published_at on the latest published brief and exits successfully (run completed).
RUN_MIN_PCT_NEW_CANDIDATES=

# Optional. Brief section shape for compose (generate-brief + regenerate-brief): paragraphs per story (1–3), soft char length per paragraph.
# BRIEF_SECTION_PARAGRAPH_COUNT=1
# BRIEF_SECTION_CHAR_TARGET=500

# Gemini API (Google AI Studio)
GEMINI_API_KEY=
# Default model used by the app (server-side).
# Recommended: gemini-3-flash-preview (fast) or gemini-3-pro-preview (better reasoning).
GEMINI_MODEL=gemini-3-flash-preview

# LangSmith tracing for Gemini calls via langsmith/wrappers/gemini
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=parrafos
LANGSMITH_TRACING=true
# Optional comma-separated tags appended to default "gemini"
LANGSMITH_GEMINI_TAGS=
